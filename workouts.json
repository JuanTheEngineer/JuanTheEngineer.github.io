    {
      "id": "asics_1-0",
      "title": "Runner's Glute & Hip Flexor Guide",
      "requirements": "Barbells or Dumbbells, Straps or Band, Knee Pad, Bench, Machines(Optional)",
      "items": [
        {
          "exerciseId": "curtsylunges",
          "reps": "15",
          "sets": "3",
          "repUnits": "reps (each side)",
          "note": "Details: Perform a lateral lunge while crossing one leg behind the other, akin to a curtsy. Use a strap or band to maintain balance and focus the load on the heel. Note: You only need to step behind your front foot. Crossing far outside your front foot is unnecessary and will lead to uneven hip posture.",
          "displayName": "Strength 1: Curtsy Lunges"
        },
        {
          "exerciseId": "barbellwalkinglunges",
          "reps": "10",
          "sets": "3",
          "repUnits": "reps (each side)",
          "note": "Details: Perform walking lunges with a barbell placed behind your neck. Ensure each knee lightly taps the ground to engage the glutes properly. Note: May swap barbell for dumbbells or body weight.",
          "displayName": "Strength 2: Barbell Walking Lunges"
        },
        {
          "exerciseId": "90degreebarbellsquats",
          "reps": "10-15",
          "sets": "4",
          "repUnits": "reps",
          "note": "Detail: Squat to a 90-degree angle, then powerfully, but with control in one motion thrust your hips upward as you rise, tightly flexing your glutes. Note: Aim for 70% of your max repetition weight or above.",
          "displayName": "Strength 3: Barbell 90° Squat with Hip Thrust"
        },
        {
          "exerciseId": "singleleghipthrusts",
          "reps": "15",
          "sets": "3",
