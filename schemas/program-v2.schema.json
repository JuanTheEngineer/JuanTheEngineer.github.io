{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkoutProgram V2",
  "description": "A workout program composed of items (single exercises or groups)",
  "type": "object",
  "required": ["id", "title", "items"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
    "title": { "type": "string", "minLength": 1 },
    "requirements": { "type": "string" },
    "description": { "type": "string" },
    "category": { "type": "string" },
    "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
    "duration": { "type": "integer", "minimum": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/definitions/singleItem" },
          { "$ref": "#/definitions/groupItem" }
        ]
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "singleItem": {
      "type": "object",
      "required": ["exerciseId"],
      "properties": {
        "exerciseId": {
          "type": "string",
          "description": "References an exercise.id from exercises.json"
        },
        "reps": { "type": "string", "description": "Override for this program" },
        "sets": { "type": "string", "description": "Override for this program" },
        "repUnits": { "type": "string", "description": "Override for this program" },
        "note": { "type": "string", "description": "Program-specific note" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "enum": ["warmup", "cooldown", "stretch", "main", "accessory", "finisher"] }
        },
        "displayName": {
          "type": "string",
          "description": "Optional override for how this exercise is labeled in the program (e.g., 'Warm Up 1: Decline Pistols')"
        }
      },
      "additionalProperties": false
    },
    "groupItem": {
      "type": "object",
      "required": ["kind", "exercises"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["superset", "compound", "circuit"],
          "description": "How the group is performed: superset=alternating, compound=back-to-back, circuit=rotating"
        },
        "note": { "type": "string", "description": "Note shared across all exercises in the group" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "displayName": {
          "type": "string",
          "description": "Optional label for the group (e.g., 'Super Set: Hip Ext + SL DB RDL')"
        },
        "exercises": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/definitions/groupMember" }
        }
      },
      "additionalProperties": false
    },
    "groupMember": {
      "type": "object",
      "required": ["exerciseId"],
      "properties": {
        "exerciseId": { "type": "string" },
        "reps": { "type": "string" },
        "sets": { "type": "string" },
        "repUnits": { "type": "string" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
