{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://juantheengineer.github.io/schemas/exercise.json",
  "title": "Exercise",
  "description": "A single exercise within a workout program",
  "type": "object",
  "oneOf": [
    {
      "description": "Standard exercise with required fields",
      "required": ["gif", "reps", "sets", "repUnits"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the exercise"
        },
        "gif": {
          "type": "string",
          "description": "Local path to exercise media file (can be empty if media not yet added)"
        },
        "cloudinaryUrl": {
          "type": "string",
          "format": "uri",
          "description": "CDN URL for the exercise media (LEGACY - use source instead)"
        },
        "startTime": {
          "type": "number",
          "minimum": 0,
          "description": "Start time in seconds for video playback (LEGACY - use source instead)"
        },
        "endTime": {
          "type": "number",
          "minimum": 0,
          "description": "End time in seconds for video playback (LEGACY - use source instead)"
        },
        "source": {
          "type": "object",
          "description": "Primary media source for this exercise",
          "required": ["type", "url"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["cloudinary", "youtube", "url", "gif"],
              "description": "Type of media source"
            },
            "url": {
              "type": "string",
              "format": "uri",
              "description": "URL to the media"
            },
            "startTime": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "Start time in seconds (0 = beginning)"
            },
            "endTime": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "End time in seconds (0 = end of video)"
            },
            "notes": {
              "type": "string",
              "description": "Notes about this source"
            }
          },
          "additionalProperties": false
        },
        "mediaType": {
          "type": "string",
          "enum": ["gif", "video", "image"],
          "description": "Type of media"
        },
        "reps": {
          "type": "string",
          "minLength": 1,
          "description": "Number of repetitions (flexible format)"
        },
        "sets": {
          "type": "string",
          "minLength": 1,
          "description": "Number of sets (flexible format)"
        },
        "note": {
          "type": "string",
          "description": "Additional instructions or form tips"
        },
        "repUnits": {
          "type": "string",
          "enum": ["reps", "secs", "min", "yd", "rep", "reps (each side)", "secs (each side)"],
          "description": "Unit of measurement for repetitions"
        },
        "alternatives": {
          "type": "array",
          "description": "Alternative video sources for this exercise",
          "items": {
            "type": "object",
            "required": ["type", "url"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["youtube", "cloudinary", "url"],
                "description": "Type of alternative media source"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "URL to the alternative media"
              },
              "startTime": {
                "type": "number",
                "minimum": 0,
                "description": "Start time in seconds (for video sources)"
              },
              "endTime": {
                "type": "number",
                "minimum": 0,
                "description": "End time in seconds (for video sources)"
              },
              "notes": {
                "type": "string",
                "description": "Notes about this alternative"
              }
            },
            "additionalProperties": false
          }
        },
        "subExercise": {
          "type": "object",
          "required": ["gif", "reps", "sets", "repUnits"],
          "properties": {
            "name": {
              "type": "string",
              "description": "Optional name for sub-exercise"
            },
            "gif": {
              "type": "string",
              "description": "Local path to exercise media file"
            },
            "cloudinaryUrl": {
              "type": "string",
              "format": "uri"
            },
            "startTime": {
              "type": "number",
              "minimum": 0,
              "description": "Start time in seconds for video playback"
            },
            "endTime": {
              "type": "number",
              "minimum": 0,
              "description": "End time in seconds for video playback"
            },
            "reps": {
              "type": "string",
              "minLength": 1
            },
            "sets": {
              "type": "string",
              "minLength": 1
            },
            "note": {
              "type": "string"
            },
            "repUnits": {
              "type": "string",
              "enum": ["reps", "secs", "min", "yd", "rep", "reps (each side)", "secs (each side)"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Compound exercise container (only has name and compoundExercises array)",
      "required": ["name", "compoundExercises"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the compound exercise set"
        },
        "compoundExercises": {
          "type": "array",
          "description": "Array of exercises for complex compound sets",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["gif", "reps", "sets", "repUnits"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Optional name"
              },
              "gif": {
                "type": "string"
              },
              "cloudinaryUrl": {
                "type": "string",
                "format": "uri"
              },
              "startTime": {
                "type": "number",
                "minimum": 0,
                "description": "Start time in seconds for video playback"
              },
              "endTime": {
                "type": "number",
                "minimum": 0,
                "description": "End time in seconds for video playback"
              },
              "reps": {
                "type": "string",
                "minLength": 1
              },
              "sets": {
                "type": "string",
                "minLength": 1
              },
              "note": {
                "type": "string"
              },
              "repUnits": {
                "type": "string",
                "enum": ["reps", "secs", "min", "yd", "rep", "reps (each side)", "secs (each side)"]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  ]
}
