{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://juantheengineer.github.io/schemas/exercise.json",
  "title": "Exercise",
  "description": "A single exercise within a workout program",
  "type": "object",
  "oneOf": [
    {
      "description": "Standard exercise with required fields",
      "required": ["gif", "reps", "sets", "repUnits"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the exercise"
        },
        "gif": {
          "type": "string",
          "description": "Local path to exercise media file (can be empty if media not yet added)"
        },
        "cloudinaryUrl": {
          "type": "string",
          "format": "uri",
          "description": "CDN URL for the exercise media"
        },
        "mediaType": {
          "type": "string",
          "enum": ["gif", "video", "image"],
          "description": "Type of media"
        },
        "reps": {
          "type": "string",
          "minLength": 1,
          "description": "Number of repetitions (flexible format)"
        },
        "sets": {
          "type": "string",
          "minLength": 1,
          "description": "Number of sets (flexible format)"
        },
        "note": {
          "type": "string",
          "description": "Additional instructions or form tips"
        },
        "repUnits": {
          "type": "string",
          "enum": ["reps", "secs", "min", "yd", "rep", "reps (each side)", "secs (each side)"],
          "description": "Unit of measurement for repetitions"
        },
        "subExercise": {
          "type": "object",
          "required": ["gif", "reps", "sets", "repUnits"],
          "properties": {
            "name": {
              "type": "string",
              "description": "Optional name for sub-exercise"
            },
            "gif": {
              "type": "string",
              "description": "Local path to exercise media file"
            },
            "cloudinaryUrl": {
              "type": "string",
              "format": "uri"
            },
            "reps": {
              "type": "string",
              "minLength": 1
            },
            "sets": {
              "type": "string",
              "minLength": 1
            },
            "note": {
              "type": "string"
            },
            "repUnits": {
              "type": "string",
              "enum": ["reps", "secs", "min", "yd", "rep", "reps (each side)", "secs (each side)"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Compound exercise container (only has name and compoundExercises array)",
      "required": ["name", "compoundExercises"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Display name of the compound exercise set"
        },
        "compoundExercises": {
          "type": "array",
          "description": "Array of exercises for complex compound sets",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["gif", "reps", "sets", "repUnits"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Optional name"
              },
              "gif": {
                "type": "string"
              },
              "cloudinaryUrl": {
                "type": "string",
                "format": "uri"
              },
              "reps": {
                "type": "string",
                "minLength": 1
              },
              "sets": {
                "type": "string",
                "minLength": 1
              },
              "note": {
                "type": "string"
              },
              "repUnits": {
                "type": "string",
                "enum": ["reps", "secs", "min", "yd", "rep", "reps (each side)", "secs (each side)"]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  ]
}
