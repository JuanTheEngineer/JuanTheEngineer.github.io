{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://juantheengineer.github.io/schemas/program.json",
  "title": "WorkoutProgram",
  "description": "A workout program - the composable unit for saving, displaying, and sharing workouts",
  "type": "object",
  "required": ["id", "title", "requirements", "exercises"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]+$",
      "description": "Unique identifier for the program (kebab-case)",
      "examples": ["agility_lower_1-1", "ppl_push_day_1-0", "asics_1-0"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Display title of the workout program",
      "examples": [
        "Agility Lower Body Program 1.1",
        "PPL 3-Day Rotation: Push Day 1"
      ]
    },
    "requirements": {
      "type": "string",
      "description": "Equipment or prerequisites needed for this program",
      "examples": [
        "Dumbbells, Exercise Band, Swiss Ball, Trap Bar",
        "Barbells, Bench, Dumbbells, Exercise Band"
      ]
    },
    "description": {
      "type": "string",
      "description": "Optional detailed description of the program"
    },
    "category": {
      "type": "string",
      "description": "Program category (e.g., 'strength', 'agility', 'ppl')",
      "examples": ["agility", "ppl", "strength", "mobility"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Difficulty level of the program"
    },
    "duration": {
      "type": "integer",
      "minimum": 1,
      "description": "Estimated duration in minutes"
    },
    "exercises": {
      "type": "array",
      "minItems": 1,
      "description": "Array of exercises in this program",
      "items": {
        "$ref": "exercise.json"
      }
    },
    "tags": {
      "type": "array",
      "description": "Tags for search and filtering",
      "items": {
        "type": "string"
      },
      "examples": [["lower-body", "agility"], ["push", "chest", "shoulders"]]
    },
    "author": {
      "type": "string",
      "description": "Author or creator of the program"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when program was created"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    }
  },
  "additionalProperties": false
}
